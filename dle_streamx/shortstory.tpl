<article class="card">
	<a class="card__thumb" href="{full-link}">
		[image-1]<img src="{image-1}" alt="{title}">[/image-1]
	</a>
	<div class="card__body">
		<h3 class="card__title"><a href="{full-link}">{title}</a></h3>
		<div class="card__meta">
			<span class="meta__rating">★ {rating}</span>
			<span class="meta__year">{date=Y}</span>
			<span class="meta__cat">{link-category}</span>
			<span class="meta__views">👁 {views}</span>
			<span class="meta__comments">💬 {comments-num}</span>
		</div>
		<div class="card__desc">{short-story limit="220"}</div>
	</div>
</article>

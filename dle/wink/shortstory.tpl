<article class="card">
    <a class="card-thumb" href="{full-link}">
        {image-1}
    </a>
    <div class="card-body">
        <h3 class="card-title"><a href="{full-link}">{title}</a></h3>
        <div class="card-meta">
            <span class="card-date">{date}</span>
            [rating]<span class="card-rating">★ {rating}</span>[/rating]
        </div>
        <div class="card-excerpt">{short-story limit="160"}</div>
        <div class="card-actions">
            <a class="btn btn-tertiary" href="{full-link}">Подробнее</a>
        </div>
    </div>
</article>

